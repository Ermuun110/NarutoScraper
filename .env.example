# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Anthropic (AI vision check for ambiguous titles) — optional
ANTHROPIC_API_KEY=sk-ant-xxxx

# Optional: comma-separated search keywords (each is space-separated AND terms).
# Default below. Order within a keyword doesn't matter; latin case doesn't either.
SEARCH_KEYWORDS=ナルト カード サンプル,ナルト カード SAMPLE

# Optional: cron schedule (default every 5 min)
CRON_SCHEDULE=*/5 * * * *
